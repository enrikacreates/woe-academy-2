# Sanity CMS
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production

# MailerLite
MAILERLITE_API_KEY=your_mailerlite_api_key_here
# Optional: Group ID to add hero form subscribers to (found in MailerLite → Groups)
MAILERLITE_GROUP_ID=your_group_id_here
# Email to receive contact form notification (if using transactional email)
CONTACT_NOTIFY_EMAIL=info@woeacademy.com
