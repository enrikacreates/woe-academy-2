---
interface Props {
  phone?: string;
  email?: string;
  address?: string;
  hours?: string;
}

const {
  phone = "(949) 555-0123",
  email = "info@woeacademy.com",
  address = "Irvine, Tustin Ranch & Woodbridge, CA",
  hours = "Monday - Friday: 6:30 AM - 6:30 PM\nSaturday - Sunday: Closed",
} = Astro.props;
---

<section id="contact">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Ready to Get Started?</p>
      <h2>Visit Our Academy Today</h2>
      <p class="section-description">Schedule a tour to see our facilities, meet our educators, and discover how World Of Explorers Academy can support your child's growth and development.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item">
          <div class="contact-icon icon-circle icon-teal">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="contact-details">
            <h3>Locations We Serve</h3>
            <p>{address}</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon icon-circle" style="background: #ecfeff; color: #0891b2;">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <div class="contact-details">
            <h3>Phone</h3>
            <p>{phone}</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon icon-circle icon-blue">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="contact-details">
            <h3>Email</h3>
            <p>{email}</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon icon-circle icon-amber">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="contact-details">
            <h3>Operating Hours</h3>
            <p set:html={hours.replace(/\n/g, '<br>')} />
          </div>
        </div>
        <div class="trust-badge">
          <p><span class="highlight">Fully Licensed & Insured:</span> Our facility meets all California state requirements for childcare and maintains the highest safety standards for your peace of mind.</p>
        </div>
      </div>

      <div class="contact-form">
        <h3>Schedule Your Visit</h3>
        <p class="form-description">Fill out the form below and we'll contact you within 24 hours to schedule your tour.</p>
        <form id="contact-form">
          <div class="form-group">
            <label for="name">Parent/Guardian Name *</label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required placeholder="your.email@example.com" />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number *</label>
            <input type="tel" id="phone" name="phone" required placeholder="(949) 555-0123" />
          </div>
          <div class="form-group">
            <label for="message">Tell us about your child</label>
            <textarea id="message" name="message" rows="4" placeholder="Child's age, program interests, preferred schedule..."></textarea>
          </div>
          <button type="submit" class="btn-primary form-submit">Request a Tour</button>
          <p class="form-disclaimer">By submitting this form, you agree to be contacted by World Of Explorers Academy.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        form.innerHTML = '<p style="color: #14b8a6; font-weight: 600; font-size: 1.125rem;">✓ Thank you! We\'ll be in touch within 24 hours to schedule your tour.</p>';
      } else {
        alert('Something went wrong. Please try again or call us directly.');
      }
    } catch {
      alert('Something went wrong. Please try again or call us directly.');
    }
  });
</script>
