---
interface Props {
  heading?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  missionQuote?: string;
  missionStatement?: string;
  features?: { text: string }[];
  buttonText?: string;
  stats?: { value: string; label: string }[];
}

const {
  heading = "Why Irvine Families Choose World Of Explorers Academy",
  description = "Working parents in Irvine deserve more than just supervision for their children. At World Of Explorers Academy (W.O.E. Academy), we provide a nurturing environment where your child develops critical life skills, explores their interests, and builds lasting friendships.",
  image = "https://images.unsplash.com/photo-1588075592446-265fd1e6e76f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080",
  imageAlt = "Educator engaging with children in learning activities",
  missionQuote = "Where Curious Kids Become Confident Learners",
  missionStatement = "Our mission is to create a safe, engaging space where children can explore, learn, and grow at their own pace. We believe every child has unique potential waiting to be discovered through hands-on learning, creative play, and supportive guidance.",
  features = [
    { text: "Individual attention with low student-to-teacher ratios" },
    { text: "Curriculum designed for holistic development" },
    { text: "Safe, clean, and stimulating learning environments" },
  ],
  buttonText = "Learn More About Us",
  stats = [
    { value: "15+", label: "Years of Experience" },
    { value: "500+", label: "Happy Families" },
    { value: "100%", label: "Licensed & Insured" },
  ],
} = Astro.props;
---

<section id="about">
  <div class="container">
    <div class="section-header">
      <h2>{heading}</h2>
      <p class="section-description">{description}</p>
    </div>
    <div class="about-grid">
      <div class="rounded-image">
        <img src={image} alt={imageAlt} loading="lazy" />
      </div>
      <div class="about-card">
        <h3>"{missionQuote}"</h3>
        <p>{missionStatement}</p>
        <div class="about-features">
          {features.map((item) => (
            <div class="feature-item">
              <span class="checkmark">✓</span>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
        <a href="#contact" class="btn-primary">{buttonText}</a>
      </div>
    </div>
    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-item">
          <div class="stat-number">{stat.value}</div>
          <div>{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
