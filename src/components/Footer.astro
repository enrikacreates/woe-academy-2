---
import Logo from './Logo.astro';

interface Props {
  phone?: string;
  email?: string;
  address?: string;
}

const {
  phone = "(949) 555-0123",
  email = "info@woeacademy.com",
  address = "Serving Irvine, Tustin Ranch\n& Woodbridge, CA",
} = Astro.props;
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <Logo size="2.5rem" gradientId="footer-gradient" />
          <div>
            <h3>World Of Explorers</h3>
            <p>Academy</p>
          </div>
        </div>
        <p class="footer-text">Irvine's premier childcare & afterschool program building confident, curious learners.</p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/#programs">Programs</a></li>
          <li><a href="/#about">About Us</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Programs</h4>
        <ul class="footer-text">
          <li>Preschool (Ages 2-5)</li>
          <li>Full-Day Care</li>
          <li>Before/After School</li>
          <li>Seasonal Camps</li>
          <li>Ages 2-12 Years</li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul class="footer-text">
          {address.split('\n').map((line: string) => <li>{line}</li>)}
          <li>{phone}</li>
          <li>{email}</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} World Of Explorers Academy. All rights reserved. | Licensed California Childcare Facility</p>
    </div>
  </div>
</footer>
