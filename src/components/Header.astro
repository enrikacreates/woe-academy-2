---
import Logo from './Logo.astro';

interface Props {
  logoImage?: string;
  logoAlt?: string;
  title?: string;
  subtitle?: string;
}

const {
  logoImage,
  logoAlt,
  title = "World Of Explorers Academy",
  subtitle = "Childcare & Afterschool Program",
} = Astro.props;
---

<header>
  <div class="container">
    <div class="header-content">
      <a href="/" class="logo-section" style="text-decoration: none;">
        <Logo size="3rem" gradientId="header-gradient" image={logoImage} alt={logoAlt} />
        <div class="logo-text">
          <h1>{title}</h1>
          <p>{subtitle}</p>
        </div>
      </a>
      <nav>
        <a href="/">Home</a>
        <a href="/#programs">Programs</a>
        <a href="/#about">About Us</a>
        <a href="/blog">Blog</a>
        <a href="/#contact">Contact</a>
      </nav>
      <a href="/#contact" class="btn-primary desktop-only">Enroll Now</a>
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" style="display: none; padding: 1rem 0; border-top: 1px solid #e5e7eb;">
      <nav style="display: flex; flex-direction: column; gap: 1rem;">
        <a href="/">Home</a>
        <a href="/#programs">Programs</a>
        <a href="/#about">About Us</a>
        <a href="/blog">Blog</a>
        <a href="/#contact">Contact</a>
        <a href="/#contact" class="btn-primary" style="text-align: center;">Enroll Now</a>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu!.style.display = menu!.style.display === 'none' ? 'block' : 'none';
  });
</script>
