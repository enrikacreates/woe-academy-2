---
---

<section id="programs" class="programs-bg">
  <div class="container">
    <div class="section-header">
      <p class="section-label">What Sets Us Apart</p>
      <h2>What Makes Us Different</h2>
      <p class="section-description">We go beyond basic childcare to provide a comprehensive learning experience that supports your child's development in every area.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="icon-circle icon-green">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Safe & Licensed</h3>
        <p>Fully licensed California childcare facility with rigorous safety protocols and secure check-in/check-out procedures.</p>
      </div>
      <div class="feature-card">
        <div class="icon-circle icon-teal">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <h3>Flexible Programs</h3>
        <p>Full-day care, before/after school, and seasonal camps designed to work seamlessly with your busy schedule.</p>
      </div>
      <div class="feature-card">
        <div class="icon-circle icon-blue">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3>Small Group Focus</h3>
        <p>Low child-to-teacher ratios ensure every child receives individual attention and personalized learning.</p>
      </div>
      <div class="feature-card">
        <div class="icon-circle icon-pink">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 3l14 9-14 9V3z"></path>
            <line x1="19" y1="3" x2="19" y2="21"></line>
          </svg>
        </div>
        <h3>STEM & Creative Learning</h3>
        <p>Hands-on activities that go beyond typical daycare, fostering curiosity through science, art, and exploration.</p>
      </div>
      <div class="feature-card">
        <div class="icon-circle icon-amber">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
            <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
          </svg>
        </div>
        <h3>Experienced Educators</h3>
        <p>Background-checked, certified staff who are passionate about early childhood development and education.</p>
      </div>
    </div>

    <div class="programs-card">
      <h3>Programs Tailored to Every Age</h3>
      <div class="programs-grid">
        <div class="program-item bg-teal-50">
          <div class="emoji">🎨</div>
          <h4>Preschool</h4>
          <p>Ages 2-5 years</p>
        </div>
        <div class="program-item bg-cyan-50">
          <div class="emoji">☀️</div>
          <h4>Full-Day Care</h4>
          <p>6:30 AM - 6:30 PM</p>
        </div>
        <div class="program-item bg-blue-50">
          <div class="emoji">🎒</div>
          <h4>Before/After School</h4>
          <p>Ages 5-12 years</p>
        </div>
        <div class="program-item bg-amber-50">
          <div class="emoji">🏕️</div>
          <h4>Seasonal Camps</h4>
          <p>Summer & Holidays</p>
        </div>
      </div>
    </div>
  </div>
</section>
