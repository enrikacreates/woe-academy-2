---
interface Props {
  sectionLabel?: string;
  sectionHeading?: string;
  sectionDescription?: string;
  featureCards?: { icon: string; title: string; description: string }[];
  subheading?: string;
  programItems?: { emoji: string; title: string; ageRange: string }[];
}

const {
  sectionLabel = "What Sets Us Apart",
  sectionHeading = "What Makes Us Different",
  sectionDescription = "We go beyond basic childcare to provide a comprehensive learning experience that supports your child's development in every area.",
  featureCards = [
    { icon: "shield", title: "Safe & Licensed", description: "Fully licensed California childcare facility with rigorous safety protocols and secure check-in/check-out procedures." },
    { icon: "calendar", title: "Flexible Programs", description: "Full-day care, before/after school, and seasonal camps designed to work seamlessly with your busy schedule." },
    { icon: "users", title: "Small Group Focus", description: "Low child-to-teacher ratios ensure every child receives individual attention and personalized learning." },
    { icon: "play", title: "STEM & Creative Learning", description: "Hands-on activities that go beyond typical daycare, fostering curiosity through science, art, and exploration." },
    { icon: "graduation", title: "Experienced Educators", description: "Background-checked, certified staff who are passionate about early childhood development and education." },
  ],
  subheading = "Programs Tailored to Every Age",
  programItems = [
    { emoji: "🎨", title: "Preschool", ageRange: "Ages 2-5 years" },
    { emoji: "☀️", title: "Full-Day Care", ageRange: "6:30 AM - 6:30 PM" },
    { emoji: "🎒", title: "Before/After School", ageRange: "Ages 5-12 years" },
    { emoji: "🏕️", title: "Seasonal Camps", ageRange: "Summer & Holidays" },
  ],
} = Astro.props;

const iconMap: Record<string, string> = {
  shield: `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
  calendar: `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>`,
  users: `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
  play: `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l14 9-14 9V3z"></path><line x1="19" y1="3" x2="19" y2="21"></line></svg>`,
  graduation: `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>`,
};

const iconColors: Record<string, string> = {
  shield: "icon-green",
  calendar: "icon-teal",
  users: "icon-blue",
  play: "icon-pink",
  graduation: "icon-amber",
};

const programBgColors = ["bg-teal-50", "bg-cyan-50", "bg-blue-50", "bg-amber-50"];
---

<section id="programs" class="programs-bg">
  <div class="container">
    <div class="section-header">
      <p class="section-label">{sectionLabel}</p>
      <h2>{sectionHeading}</h2>
      <p class="section-description">{sectionDescription}</p>
    </div>

    <div class="features-grid">
      {featureCards.map((card) => (
        <div class="feature-card">
          <div class={`icon-circle ${iconColors[card.icon] || "icon-green"}`}>
            <Fragment set:html={iconMap[card.icon] || iconMap.shield} />
          </div>
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </div>
      ))}
    </div>

    <div class="programs-card">
      <h3>{subheading}</h3>
      <div class="programs-grid">
        {programItems.map((item, i) => (
          <div class={`program-item ${programBgColors[i % programBgColors.length]}`}>
            <div class="emoji">{item.emoji}</div>
            <h4>{item.title}</h4>
            <p>{item.ageRange}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
