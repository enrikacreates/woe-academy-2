---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Programs from '../components/Programs.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, urlFor, queries } from '../lib/sanity';

const settings = await sanityClient.fetch(queries.siteSettings);

// Build image URLs from Sanity if available
const heroImage = settings?.heroImage ? urlFor(settings.heroImage).width(1080).quality(80).url() : undefined;
const aboutImage = settings?.aboutImage ? urlFor(settings.aboutImage).width(1080).quality(80).url() : undefined;

// Format address for footer (multiline)
const footerAddress = settings?.address
  ? `${settings.address}${settings.serviceAreas ? '\n' + settings.serviceAreas : ''}`
  : undefined;
---

<Layout
  title="World Of Explorers Academy | Irvine's Premier Childcare & Afterschool Program"
  description="Serving families in Irvine, Tustin Ranch & Woodbridge with enriching full-day care, afterschool programs, and seasonal camps for ages 2-12 years."
  image={heroImage}
>
  <Header />
  <main>
    <Hero
      headline={settings?.heroHeadline}
      description={settings?.heroDescription}
      image={heroImage}
      buttonText={settings?.heroButtonText}
      trustIndicators={settings?.heroTrustIndicators}
    />
    <About
      heading={settings?.aboutHeading}
      description={settings?.aboutDescription}
      image={aboutImage}
      missionQuote={settings?.aboutMissionQuote}
      missionStatement={settings?.aboutMissionStatement}
      features={settings?.aboutFeatures}
      buttonText={settings?.aboutButtonText}
      stats={settings?.aboutStats}
    />
    <Programs
      sectionLabel={settings?.programsSectionLabel}
      sectionHeading={settings?.programsSectionHeading}
      sectionDescription={settings?.programsSectionDescription}
      featureCards={settings?.programsFeatureCards}
      subheading={settings?.programsSubheading}
      programItems={settings?.programItems}
    />
    <Contact
      phone={settings?.phone}
      email={settings?.email}
      address={settings?.address}
      hours={settings?.hours}
      sectionLabel={settings?.contactSectionLabel}
      sectionHeading={settings?.contactSectionHeading}
      sectionDescription={settings?.contactSectionDescription}
    />
  </main>
  <Footer
    phone={settings?.phone}
    email={settings?.email}
    address={footerAddress}
  />
</Layout>
