---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sanityClient, queries, urlFor } from '../../lib/sanity';

export const prerender = false;

const posts = await sanityClient.fetch(queries.allPosts);
---

<Layout
  title="Blog | World Of Explorers Academy"
  description="Tips, activities, and insights for families from the World Of Explorers Academy team."
>
  <Header />
  <main>
    <section class="blog-hero">
      <div class="container">
        <div class="section-header">
          <p class="section-label">From Our Educators</p>
          <h1>The W.O.E. Blog</h1>
          <p class="section-description">Tips, activities, and insights to support your child's growth and curiosity — at school and at home.</p>
        </div>
      </div>
    </section>

    <section class="blog-list-section">
      <div class="container">
        {posts.length === 0 ? (
          <div class="blog-empty">
            <p>No posts yet — check back soon! 🌱</p>
          </div>
        ) : (
          <div class="blog-grid">
            {posts.map((post: any) => (
              <article class="blog-card">
                {post.mainImage && (
                  <a href={`/blog/${post.slug.current}`} class="blog-card-image">
                    <img
                      src={urlFor(post.mainImage).width(600).height(340).fit('crop').url()}
                      alt={post.mainImage.alt ?? post.title}
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="blog-card-body">
                  {post.publishedAt && (
                    <p class="blog-card-date">
                      {new Date(post.publishedAt).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                      {post.estimatedReadingTime && ` · ${post.estimatedReadingTime} min read`}
                    </p>
                  )}
                  <h2>
                    <a href={`/blog/${post.slug.current}`}>{post.title}</a>
                  </h2>
                  {post.excerpt && <p class="blog-card-excerpt">{post.excerpt}</p>}
                  <a href={`/blog/${post.slug.current}`} class="blog-read-more">
                    Read more →
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .blog-hero {
    background: linear-gradient(135deg, #f0fdfa 0%, #ccfbf1 100%);
    padding: 5rem 0 3rem;
    text-align: center;
  }
  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: #0f172a;
    margin-bottom: 1rem;
  }
  .blog-list-section {
    padding: 4rem 0 6rem;
  }
  .blog-empty {
    text-align: center;
    padding: 4rem;
    color: #64748b;
    font-size: 1.25rem;
  }
  .blog-card-date {
    font-size: 0.85rem;
    color: #64748b;
    margin-bottom: 0.5rem;
  }
  .blog-card-excerpt {
    color: #475569;
    margin: 0.75rem 0 1rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-read-more {
    color: #14b8a6;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-read-more:hover {
    color: #0d9488;
  }
</style>
